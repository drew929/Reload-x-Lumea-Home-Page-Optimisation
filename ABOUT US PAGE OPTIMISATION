<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
  :root {
    --teal: #1DAC94;
    --slate: #222F32;
    --white: #FFFFFF;
    --grey-light: #F7F7F7;
    --grey-mid: #E7E7E7;
    --grey-dark: #626262;
    --charcoal: #4B4B4B;
    --body-text: #4C4A4B;
    --card-text: #626262;
    --max-width: 1256px;
  }
  body { font-family: 'Poppins', Arial, sans-serif; color: var(--slate); background: var(--white); font-size: 16px; line-height: 1.6; }
  h1 { font-family: 'Chakra Petch', sans-serif; font-size: 48px; font-weight: 500; line-height: 1.1; letter-spacing: -0.02em; color: var(--slate); }
  h2 { font-family: 'Chakra Petch', sans-serif; font-size: 40px; font-weight: 600; line-height: 1.4; letter-spacing: -0.02em; color: #2B2B2B; }
  h3 { font-family: 'Poppins', sans-serif; font-size: 20px; font-weight: 500; line-height: 1.5; color: var(--charcoal); }
  p { color: var(--body-text); font-size: 16px; line-height: 1.6; }
  a { text-decoration: none; color: inherit; }
  .btn { display: inline-flex; align-items: center; gap: 8px; padding: 12px 20px; border-radius: 8px; font-size: 14px; font-weight: 600; font-family: 'Poppins', sans-serif; }
  .btn-dark { background: var(--charcoal); color: var(--white); }
  .link-arrow { font-size: 16px; font-weight: 600; color: var(--teal); display: inline-flex; align-items: center; gap: 6px; }
  .link-arrow::after { content: '→'; }
  .changed { outline: 2px dashed var(--teal); outline-offset: 4px; position: relative; }
  .changed::before { content: '✦ REVISED'; position: absolute; top: -22px; left: 0; background: var(--teal); color: white; font-size: 10px; font-weight: 700; letter-spacing: 0.1em; padding: 2px 8px; border-radius: 3px; z-index: 10; white-space: nowrap; }
  .new-addition { outline: 2px dashed #f59e0b; outline-offset: 4px; position: relative; }
  .new-addition::before { content: '+ NEW'; position: absolute; top: -22px; left: 0; background: #f59e0b; color: white; font-size: 10px; font-weight: 700; letter-spacing: 0.1em; padding: 2px 8px; border-radius: 3px; z-index: 10; white-space: nowrap; }
  .legend { background: var(--slate); color: var(--white); padding: 16px 92px; display: flex; gap: 32px; align-items: center; font-size: 13px; font-family: 'Poppins', sans-serif; position: sticky; top: 0; z-index: 100; }
  .legend-item { display: flex; align-items: center; gap: 8px; }
  .legend-dot { width: 14px; height: 14px; border-radius: 2px; }
  .dot-revised { background: var(--teal); }
  .dot-new { background: #f59e0b; }
  .legend-title { font-weight: 600; font-size: 14px; margin-right: 16px; }
  .topbar { background: var(--white); padding: 10px 92px; border-bottom: 1px solid var(--grey-mid); display: flex; justify-content: flex-end; align-items: center; font-size: 12px; color: var(--body-text); gap: 16px; }
  nav { padding: 0 92px; height: 104px; display: flex; align-items: center; justify-content: space-between; border-bottom: 1px solid var(--grey-mid); }
  .nav-logo { font-family: 'Chakra Petch', sans-serif; font-size: 24px; font-weight: 600; color: var(--slate); letter-spacing: -0.02em; }
  .nav-links { display: flex; gap: 32px; }
  .nav-links a { font-size: 16px; font-weight: 600; color: var(--slate); }

  /* HERO */
  .hero { position: relative; min-height: 427px; background: linear-gradient(135deg, #d0d8da 0%, #b8c4c7 100%); display: flex; align-items: center; padding: 100px 92px; overflow: hidden; }
  .hero::after { content: ''; position: absolute; right: 80px; top: 50%; transform: translateY(-50%); width: 300px; height: 380px; background: linear-gradient(180deg, #8a9ea3 0%, #6b8188 100%); border-radius: 4px; opacity: 0.4; }
  .hero-card { background: var(--white); border-radius: 60px 0 100px; padding: 56px 40px 76px; max-width: 590px; position: relative; z-index: 2; display: flex; flex-direction: column; gap: 16px; }
  .breadcrumb { padding: 8px 92px; font-size: 12px; font-weight: 500; color: var(--grey-dark); letter-spacing: 0.1em; text-transform: uppercase; border-bottom: 1px solid var(--grey-mid); display: flex; gap: 8px; align-items: center; }
  .breadcrumb a { color: var(--grey-dark); }
  .breadcrumb span { color: var(--charcoal); font-weight: 700; }

  /* INTRO */
  .intro { padding: 100px 92px; position: relative; overflow: hidden; }
  .intro-inner { max-width: 890px; padding: 16px 20px; }
  .intro-inner p { font-size: 16px; color: #2B2B2B; line-height: 1.6; margin-top: 16px; }

  /* STRENGTH */
  .strength { padding: 100px 92px; }
  .strength-inner { max-width: var(--max-width); margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: start; }
  .strength-image { background: linear-gradient(135deg, #8a9ea3, #5a7178); border-radius: 16px; min-height: 617px; }
  .strength-content { display: flex; flex-direction: column; gap: 32px; }
  .strength-content p { color: var(--card-text); font-size: 16px; line-height: 1.6; }
  .bullet-list { display: flex; flex-direction: column; gap: 12px; }
  .bullet-item { display: flex; align-items: flex-start; gap: 16px; font-size: 16px; color: var(--charcoal); line-height: 1.6; }
  .bullet-dot { width: 16px; height: 16px; background: var(--grey-dark); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 3px; }
  .bullet-dot::after { content: ''; width: 3px; height: 6px; border: 1.5px solid white; transform: rotate(-135deg); display: block; }

  /* TRANSGRID DIAGRAM */
  .transgrid-section { background: var(--grey-dark); padding: 100px 102px; display: flex; flex-direction: column; align-items: center; gap: 60px; }
  .transgrid-section h2 { color: var(--white); text-align: center; }
  .transgrid-diagram { background: linear-gradient(135deg, #4a5e63, #3a4e53); border-radius: 16px; width: 100%; max-width: 1138px; height: 497px; display: flex; align-items: center; justify-content: center; }
  .transgrid-diagram p { color: rgba(255,255,255,0.4); font-size: 14px; }

  /* COMMUNITIES */
  .communities { padding: 100px 92px; background: var(--white); }
  .communities-inner { max-width: var(--max-width); margin: 0 auto; display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; }
  .communities-image { background: linear-gradient(135deg, #7a9ea3, #5a7e83); border-radius: 16px; min-height: 397px; }
  .communities-content { display: flex; flex-direction: column; gap: 24px; }
  .communities-content p { color: var(--charcoal); font-size: 16px; line-height: 1.6; }

  /* WHAT WE DELIVER */
  .services { padding: 100px 92px; background: var(--white); }
  .services-inner { max-width: var(--max-width); margin: 0 auto; }
  .services-header { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; margin-bottom: 60px; align-items: start; }
  .services-header p { font-size: 16px; color: var(--body-text); line-height: 1.6; }
  .services-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 32px; }
  .service-card { background: var(--grey-light); border-radius: 16px; padding: 40px; display: flex; flex-direction: column; gap: 16px; }
  .service-card p { color: var(--card-text); font-size: 15px; }

  /* LEADERSHIP */
  .leadership { padding: 100px 92px; background: var(--white); }
  .leadership-inner { max-width: var(--max-width); margin: 0 auto; display: grid; grid-template-columns: 290px 1fr; gap: 32px; align-items: start; }
  .team-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 24px; }
  .team-card { display: flex; flex-direction: column; gap: 0; }
  .team-photo { height: 210px; background: linear-gradient(135deg, #8a9ea3, #6b8188); border-radius: 4px; margin-bottom: 16px; }
  .team-info { border-left: 1px solid #000; padding: 8px 16px; }
  .team-name { font-size: 20px; font-weight: 500; color: var(--charcoal); margin-bottom: 8px; }
  .team-title { font-size: 14px; color: #A3A3A3; line-height: 1.8; }
  .team-li { margin-top: 12px; display: inline-block; width: 29px; height: 24px; background: var(--teal); border-radius: 4px; }
  .leadership-intro { display: flex; flex-direction: column; gap: 16px; }
  .leadership-intro p { font-size: 16px; color: var(--body-text); line-height: 1.6; }

  /* FOOTER */
  footer { background: var(--charcoal); padding: 50px 92px; }
  .footer-inner { max-width: 1250px; margin: 0 auto; display: flex; justify-content: space-between; align-items: flex-start; padding-bottom: 48px; border-bottom: 1px solid rgba(255,255,255,0.1); margin-bottom: 24px; }
  .footer-logo { font-family: 'Chakra Petch', sans-serif; font-size: 20px; font-weight: 600; color: var(--white); }
  .footer-col { display: flex; flex-direction: column; gap: 10px; }
  .footer-col a { font-size: 16px; font-weight: 500; color: var(--white); }
  .footer-acknowledgement { max-width: 1250px; margin: 0 auto; font-size: 14px; color: #A7ACAD; line-height: 1.3; }

  @media (max-width: 900px) {
    .strength-inner, .communities-inner, .services-header, .leadership-inner { grid-template-columns: 1fr; }
    .team-grid { grid-template-columns: repeat(2, 1fr); }
    .services-grid { grid-template-columns: 1fr; }
    h1 { font-size: 32px; }
    h2 { font-size: 28px; }
  }
</style>
</head>
